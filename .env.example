# OrbitFlow SaaS Template Environmental Variables Example
# Duplicate this file to '.env' or '.env.local' and customize.
# SECURITY: variables prefixed with 'VITE_' are PUBLIC and are bundled into browser JavaScript.
# Never put secret API keys, database passwords, private Stripe keys, or access tokens in VITE_ variables.

# Deployment Environment
VITE_APP_ENV=development
VITE_APP_NAME="OrbitFlow SaaS"
VITE_API_URL=https://api.yoursite.com/v1

# Analytical Metrics Configuration
VITE_ENABLE_MOCK_DATA=true
VITE_TELEMETRY_SAMPLE_RATE=1.0

# Optional services configurations (e.g. Stripe, Auth0, Supabase)
# VITE_SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
